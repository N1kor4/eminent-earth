---
// StudyCard.astro — Reusable card for displaying academic milestones
const { title, items = [] } = Astro.props;
---

<div class="study-card">
    <h3 class="study-card-title">{title}</h3>
    <div class="study-card-items">
        {items.map(item => (
            <div class="study-card-item">
                <p class="study-card-subtitle">{item.subtitle}</p>
                <div class="study-card-period">{item.period}</div>
            </div>
        ))}
    </div>
</div>

<style>
.study-card {
    background-color: hsl(var(--muted));
    padding: var(--space-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: transform var(--_tspeed_fast) var(--_ttiming_ease),
                box-shadow var(--_tspeed_fast) var(--_ttiming_ease);
    border-left: 4px solid hsl(var(--accent) / 0.3);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.study-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-left-color: hsl(var(--accent));
}

.study-card-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: hsl(var(--txt));
    margin-bottom: var(--space-xs);
}

.study-card-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.study-card-item {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--space-md);
}

.study-card-subtitle {
    font-size: var(--fs-md);
    color: hsl(var(--txt) / 0.85);
    margin: 0;
    line-height: var(--lh-1-4);
}

.study-card-period {
    font-size: var(--fs-sm);
    color: hsl(var(--accent));
    font-weight: 700;
    letter-spacing: 0.02em;
    text-align: right;
    white-space: nowrap;
}

@media (max-width: 600px) {
    .study-card-item {
        grid-template-columns: 1fr;
        gap: var(--space-2xs);
    }
    .study-card-period {
        text-align: left;
    }
}
</style>
