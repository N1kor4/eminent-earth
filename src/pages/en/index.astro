---
import MainLayout from "../../layouts/MainLayout.astro";
import StudyCard from "../../components/StudyCard.astro";
---

<MainLayout title="Digital Awareness" description="Welcome to my website. A guide to understanding our digital world.">

  <!-- Hero section -->
  <section class="hero">
    <div class="hero-top">
      <img src="../../nicolasrabreau.jpeg" alt="Picture of Nicolas" class="profile-pic" />
      <div class="hero-text-top">
        <h1>Hey! Welcome to my website.</h1>
        <p>I'm Nicolas, a PhD student passionate about quantum technologies and digital freedom.</p>
      </div>
    </div>
    <div class="hero-bottom">
      <p class="awareness-pitch">
        With the current threats to our privacy and the manipulation of information, it is more important than ever to understand the digital environment that surrounds us — from our hardware and software, to the philosophies of the tech companies that build them.
      </p>
      <div class="hero-actions">
        <a href="/en/guide/" class="btn-primary">Read the Guide →</a>
        <div class="social-links">
          <a href="https://www.linkedin.com/in/nicolas-rabreau/">LinkedIn</a>
          <a href="https://github.com/N1kor4">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-separator"/>

  <!-- Studies grid -->
  <section class="container">
    <h2 class="h2">My academic background</h2>
    <div class="studies-grid">
      <StudyCard
        title="Intensive Undergraduate Classes (CPGE)"
        items={[
          { subtitle: "Lycée Chateaubriand, Rennes — PC track (Physics-Chemistry)", period: "2021 – 2023" }
        ]}
      />
      <StudyCard
        title="Engineering Degree & Master"
        items={[
          { subtitle: "Grenoble INP - Phelma — Physics, Nanosciences & Microelectronics", period: "2023 – 2026" },
          { subtitle: "Université Grenoble Alpes — Master QIQE (Quantum Information & Quantum Engineering)", period: "2025 – 2026" }
        ]}
      />
      <StudyCard
        title="Internships"
        items={[
          { subtitle: "EPFL Neuchâtel — Superconducting detectors & RSFQ circuits", period: "2025" },
          { subtitle: "CNRS Grenoble — Quantum computing with superconducting qubits", period: "2026" }
        ]}
      />
      <StudyCard
        title="PhD"
        items={[
          { subtitle: "In collaboration with CNRS Grenoble & Silent Waves — TWPA studies (Traveling Waves Parametric Amplifiers)", period: "2026 – Present" }
        ]}
      />
    </div>
  </section>

  <hr class="section-separator" />

</MainLayout>

<style>
.hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  max-width: 1000px;
  margin: var(--space-xl) auto var(--space-md) auto;
  padding: 0 var(--space-md);
  text-align: left;
}

.hero-top {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  flex-wrap: wrap;
}

.hero-bottom {
  width: 100%;
}

.profile-pic {
  width: 100%;
  max-width: 200px;
  height: auto;
  aspect-ratio: 1;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  box-shadow: var(--shadow-md);
}

@media (max-width: 600px) {
  .hero {
    justify-content: center;
    text-align: center;
  }
  .profile-pic {
    max-width: 150px;
  }
  .hero-actions {
    justify-content: center;
  }
}

.hero-text-top {
  flex: 1;
  min-width: 280px;
  display: grid;
  gap: var(--space-xs);
}

.awareness-pitch {
  font-size: var(--fs-md);
  color: hsl(var(--txt) / 0.85);
  margin-block: var(--space-xs);
  border-left: 3px solid hsl(var(--accent));
  padding-left: var(--space-sm);
  background: hsl(var(--accent) / 0.05);
  padding-block: var(--space-xs);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
  margin-top: var(--space-lg);
  flex-wrap: wrap;
}

.btn-primary {
  background-color: hsl(var(--accent));
  color: hsl(var(--muted));
  padding: 0.5em 1em;
  border-radius: var(--radius-sm);
  text-decoration: none;
  font-weight: 700;
  box-shadow: var(--shadow-sm);
  transition: background-color var(--_tspeed_fast) var(--_ttiming_ease),
              transform var(--_tspeed_fast) var(--_ttiming_ease);
}

.btn-primary:hover {
  background-color: hsl(var(--accent) / 0.8);
  color: hsl(var(--muted));
  transform: translateY(-2px);
}

.social-links {
  display: flex;
  gap: 1rem;
}

.social-links a {
  color: hsl(var(--accent));
  text-decoration: none;
  font-weight: 600;
}

.social-links a:hover {
  text-decoration: underline;
}

.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 var(--space-md);
}

.studies-grid {
  display: grid;
  gap: var(--space-md);
  margin-block: var(--space-lg);
  grid-template-columns: 1fr;
}
</style>
